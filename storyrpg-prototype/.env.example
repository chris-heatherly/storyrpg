# =============================================================================
# StoryRPG — environment template
# Copy to .env and fill in values:  cp .env.example .env
# Never commit .env (secrets). This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Core API keys (generation)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Client / Expo (bundled; only non-secret flags here — never put server secrets
# behind EXPO_PUBLIC_*)
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_PROXY_URL=http://localhost:3001
# EXPO_PUBLIC_LLM_PROVIDER=anthropic
# EXPO_PUBLIC_LLM_MODEL=claude-sonnet-4-6
#
# --- Pipeline cost/correctness (docs/PROJECT_AUDIT_2026-05-28.md, Track C) ---
# C2/C3: grade QA with a different (cheaper, decorrelated-from-author) model.
# Leave unset to use the main model. Decorrelating the judge from the author is
# the point — set this to a different model than EXPO_PUBLIC_LLM_MODEL.
# EXPO_PUBLIC_QA_LLM_PROVIDER=anthropic
# EXPO_PUBLIC_QA_LLM_MODEL=claude-haiku-4-5-20251001
# C4: hard ceiling on total LLM tokens per story (0/unset = no ceiling).
# EXPO_PUBLIC_TOKEN_BUDGET_PER_STORY=0
# EXPO_PUBLIC_IMAGE_PROVIDER=nano-banana
# EXPO_PUBLIC_IMAGE_GENERATION_ENABLED=true
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-image
# EXPO_PUBLIC_DEBUG=false
# EXPO_PUBLIC_BLOB_MANIFEST_URL=

# -----------------------------------------------------------------------------
# Proxy server (proxy-server.js) — not exposed to the Expo bundle by default
# -----------------------------------------------------------------------------
# PORT=3001
# PROXY_URL=http://localhost:3001
# PROXY_PUBLIC_URL=
# MEMORY_DIR=
#
# --- Proxy security (see docs/PROJECT_AUDIT_2026-05-28.md, L1) ---
# CORS: localhost is always allowed. Add any extra browser origins (e.g. the
# deployed reader) as a comma-separated list. Leave PROXY_ALLOW_ALL_ORIGINS
# unset in any exposed environment.
# PROXY_ALLOWED_ORIGINS=https://your-reader.vercel.app
# PROXY_ALLOW_ALL_ORIGINS=0
#
# Auth gate: OFF by default (local dev). REQUIRED before exposing the proxy
# (ngrok / deploy): set PROXY_REQUIRE_AUTH=1 and a strong PROXY_API_TOKEN so
# the worker/CLI can authenticate via `Authorization: Bearer <token>`.
# PROXY_REQUIRE_AUTH=0
# PROXY_API_TOKEN=

# -----------------------------------------------------------------------------
# OAuth / Passport (proxy only) — Google Cloud + Discord Developer Portal
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public origin of the proxy (no trailing slash). Callbacks default from this.
# AUTH_BASE_URL=http://localhost:3001
# GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# After OAuth, browser opens this URL (include ?afterAuth=home for local SPA flow).
# Reader (port 8081):
# AUTH_SUCCESS_REDIRECT=http://localhost:8081/?afterAuth=home
# AUTH_FAILURE_REDIRECT=http://localhost:8081/?auth=error
# Creator / generator app (port 8082):
# AUTH_SUCCESS_REDIRECT=http://localhost:8082/?afterAuth=home
# AUTH_FAILURE_REDIRECT=http://localhost:8082/?auth=error

# Cloud SQL Auth Proxy (terminal 1: npm run db:proxy — keep running)
# CLOUD_SQL_INSTANCE=sd-mvp:us-central1:sd-mvp
# CLOUD_SQL_PORT=5433

# Postgres via proxy (terminal 2: npm run db:migrate && npm run db:verify)
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5433/story_rpg_db

# First admin (optional): set role in SQL after first signup:
# UPDATE users SET role = 'admin' WHERE email = 'you@example.com';

# Email/password accounts (file store: .auth-users.json on proxy). Set AUTH_LOCAL_ENABLED=0 to disable.
# AUTH_ALLOW_REGISTRATION=0

# Session cookie signing — 16+ random characters in production
SESSION_SECRET=

# Production / HTTPS (Cloud Run, reverse proxy)
# TRUST_PROXY=1
# NODE_ENV=production
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Optional providers
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ATLAS_CLOUD_API_KEY=
# ATLAS_CLOUD_MODEL=
# MIDAPI_TOKEN=
