# =============================================================================
# StoryRPG — environment template
# Copy to .env and fill in values:  cp .env.example .env
# Never commit .env (secrets). This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Core API keys (generation)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Client / Expo (bundled; only non-secret flags here — never put server secrets
# behind EXPO_PUBLIC_*)
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_PROXY_URL=http://localhost:3001
# EXPO_PUBLIC_LLM_PROVIDER=anthropic
# EXPO_PUBLIC_LLM_MODEL=claude-sonnet-4-6
# EXPO_PUBLIC_IMAGE_PROVIDER=nano-banana
# EXPO_PUBLIC_IMAGE_GENERATION_ENABLED=true
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-image
# EXPO_PUBLIC_DEBUG=false
# EXPO_PUBLIC_BLOB_MANIFEST_URL=

# -----------------------------------------------------------------------------
# Proxy server (proxy-server.js) — not exposed to the Expo bundle by default
# -----------------------------------------------------------------------------
# PORT=3001
# PROXY_URL=http://localhost:3001
# PROXY_PUBLIC_URL=
# MEMORY_DIR=

# -----------------------------------------------------------------------------
# OAuth / Passport (proxy only) — Google Cloud + Discord Developer Portal
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public origin of the proxy (no trailing slash). Callbacks default from this.
# AUTH_BASE_URL=http://localhost:3001
# GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# After OAuth, browser opens this URL (include ?afterAuth=home for local SPA flow).
# AUTH_SUCCESS_REDIRECT=http://localhost:8081/?afterAuth=home
# AUTH_FAILURE_REDIRECT=http://localhost:8081/?auth=error

# Session cookie signing — 16+ random characters in production
SESSION_SECRET=

# Production / HTTPS (Cloud Run, reverse proxy)
# TRUST_PROXY=1
# NODE_ENV=production
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Optional providers
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ATLAS_CLOUD_API_KEY=
# ATLAS_CLOUD_MODEL=
# MIDAPI_TOKEN=
