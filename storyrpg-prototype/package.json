{
  "name": "storyrpg-prototype",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "proxy": "node proxy-server.js",
    "proxy:compose:up": "docker compose -f docker-compose.proxy.yml up -d",
    "proxy:compose:down": "docker compose -f docker-compose.proxy.yml down",
    "proxy:compose:logs": "docker compose -f docker-compose.proxy.yml logs -f",
    "proxy:health": "node -e \"fetch('http://localhost:3001/').then(async (r)=>{if(!r.ok){console.error('Proxy unhealthy:',r.status);process.exit(1)} const j=await r.json(); if(j?.status!=='ok'){console.error('Proxy unhealthy payload',j);process.exit(1)} console.log('Proxy healthy')}).catch((e)=>{console.error('Proxy unreachable:',e.message);process.exit(1)})\"",
    "dev": "killall node || true; CI=false npm run proxy & CI=false npm run web",
    "test": "vitest run",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:test && npm run typecheck:contracts",
    "validate": "npm run typecheck && npm test",
    "clean:runtime": "node scripts/clean-runtime-artifacts.mjs",
    "generate": "npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:heist": "STORY_TYPE=heist npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:fantasy": "STORY_TYPE=fantasy npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:doc": "npx ts-node --esm src/ai-agents/generate-from-document.ts",
    "generate:template": "npx ts-node --esm src/ai-agents/generate-from-document.ts --template"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.31",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.563.0",
    "pdfjs-dist": "^3.11.174",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "sharp": "^0.34.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/react": "~19.1.0",
    "@vercel/blob": "^2.3.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.9",
    "buffer": "^6.0.3",
    "cors": "^2.8.5",
    "crypto-browserify": "^3.12.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true
}
