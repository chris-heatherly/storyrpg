{
  "name": "storyrpg-prototype",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "STORYRPG_APP_TARGET=reader expo start --web",
    "reader:web": "STORYRPG_APP_TARGET=reader expo start --web --port 8081",
    "reader:export": "STORYRPG_APP_TARGET=reader npx expo export --platform web --output-dir dist-reader",
    "reader:export:with-content": "npm run reader:export && READER_CONTENT_OUTPUT_DIR=dist-reader/reader-content npm run content:reader:export",
    "reader:typecheck": "tsc -p tsconfig.reader.json --noEmit",
    "generator:web": "STORYRPG_APP_TARGET=generator expo start --web --port 8082",
    "generator:typecheck": "tsc -p tsconfig.generator.json --noEmit",
    "generator:export:internal": "STORYRPG_APP_TARGET=generator npx expo export --platform web --output-dir dist-generator-internal",
    "proxy": "node proxy-server.js",
    "proxy:compose:up": "docker compose -f docker-compose.proxy.yml up -d",
    "proxy:compose:down": "docker compose -f docker-compose.proxy.yml down",
    "proxy:compose:logs": "docker compose -f docker-compose.proxy.yml logs -f",
    "proxy:health": "node -e \"fetch('http://localhost:3001/').then(async (r)=>{if(!r.ok){console.error('Proxy unhealthy:',r.status);process.exit(1)} const j=await r.json(); if(j?.status!=='ok'){console.error('Proxy unhealthy payload',j);process.exit(1)} console.log('Proxy healthy')}).catch((e)=>{console.error('Proxy unreachable:',e.message);process.exit(1)})\"",
    "dev": "killall node || true; CI=false npm run proxy & CI=false npm run web",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:test && npm run typecheck:contracts && npm run typecheck:worker",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 431",
    "prepare": "cd .. && git config core.hooksPath .githooks || true",
    "validate": "npm run typecheck && npm run lint && npm test",
    "check:reader-boundary": "node scripts/check-reader-boundary.mjs",
    "check:monolith-size": "node scripts/check-monolith-size.mjs",
    "verify:reader": "npm run reader:export && node scripts/check-reader-boundary.mjs --require-bundle",
    "validate:reader": "npm run reader:typecheck && npm run check:reader-boundary && npm test -- storyLibrary storyEngine conditionEvaluator resolutionEngine",
    "db:proxy": "bash scripts/run-db-proxy.sh",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:verify": "node scripts/verify-db-connection.mjs",
    "clean:runtime": "node scripts/clean-runtime-artifacts.mjs",
    "content:reader:export": "node scripts/export-reader-content.mjs",
    "generate": "npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:heist": "STORY_TYPE=heist npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:fantasy": "STORY_TYPE=fantasy npx ts-node --esm src/ai-agents/example-usage.ts",
    "generate:doc": "npx ts-node --esm src/ai-agents/generate-from-document.ts",
    "generate:template": "npx ts-node --esm src/ai-agents/generate-from-document.ts --template",
    "analyze:stat-balance": "npx ts-node --esm scripts/analyze-stat-balance.ts",
    "validate:assets": "npx ts-node --esm scripts/validate-assets.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:story": "npx playwright test --grep",
    "upload:gcs:latest": "npx ts-node --esm scripts/upload-stories-to-gcs.ts --latest",
    "upload:gcs:all": "npx ts-node --esm scripts/upload-stories-to-gcs.ts --all"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.17.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo": "~54.0.31",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "lucide-react-native": "^0.563.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.21.0",
    "posthog-js": "^1.372.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2",
    "undici": "^6.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.30",
    "@types/react": "~19.1.0",
    "@vercel/blob": "^2.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.9",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "globals": "^17.6.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.18"
  },
  "private": true
}
