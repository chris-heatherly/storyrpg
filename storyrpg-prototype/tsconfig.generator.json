{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@storyrpg/app-entry": ["apps/generator/GeneratorApp.tsx"]
    }
  },
  "include": [
    "index.ts",
    "apps/generator/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
