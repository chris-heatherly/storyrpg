{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "react-native": ["src/ai-agents/server/react-native-shim.ts"],
      "expo-file-system": ["src/ai-agents/server/expo-file-system-shim.ts"]
    },
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "src/ai-agents/server/**/*.ts"
  ],
  "exclude": [
    "src/ai-agents/server/**/*.test.ts"
  ]
}

